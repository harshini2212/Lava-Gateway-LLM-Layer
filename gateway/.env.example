# Lava-style LLM Gateway — configuration
# Copy to `.env` (git-ignored). The gateway runs with NONE of these set:
# with no provider key it meters a deterministic simulated backend.

PORT=8787

# Admin key required to mint spend keys (POST /v1/keys). Change in production.
LAVA_ADMIN_KEY=admin_dev_key

# Provider keys. Set either/both to forward real traffic and meter real usage.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Gateway's take on metered usage, in basis points (500 = 5%). Drives the invoice.
GATEWAY_FEE_BPS=500

# Seed a fixed demo spend key on boot in non-production (lava_sk_demo_key, $5 budget).
SEED_DEMO_KEY=true
