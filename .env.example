# Copy to .env and fill in to enable live Claude model backends.
# Without a key, Comptroller runs fully offline on the deterministic
# heuristic/ML backend — every workflow, model, and eval still runs.

ANTHROPIC_API_KEY=

# Default model backend used by agents when a key is present.
# Options: offline-heuristic | claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
COMPTROLLER_DEFAULT_BACKEND=claude-opus-4-8

# Deterministic seed for synthetic data + model training.
COMPTROLLER_SEED=7

# Effort for Claude backends (low | medium | high | xhigh | max).
COMPTROLLER_EFFORT=high
